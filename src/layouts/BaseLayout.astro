---
import { ClientRouter } from "astro:transitions";
import "../stylesheets/global.css";
import "../stylesheets/navbar.css";

const { title } = Astro.props;

---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="tab_icon.ico" />
		<meta name="viewport" content="initial-scale=1.0, user-scalable=no" />
		<meta name="generator" content= {Astro.generator} />
		<title> {title} </title>

	    <link href="https://fonts.googleapis.com/css2?family=Prompt:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">

        <!-- bs -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-ENjdO4Dr2bkBIFxQpeoTz1HIcje39Wm4jDKdf19U8gI4ddQ3GYNS7NTKfAdVQSZe" crossorigin="anonymous" />

		<ClientRouter />
	</head>

    <body>
        <div>
            <slot />    
        </div>
    </body>
</html>

<script>
	// force remove the astro menu during testing
	document.addEventListener("astro:page-load", () => {
		console.log("Connected");

		const astro = document.querySelector("astro-dev-toolbar");
		if (astro) 
			astro.remove();
	})
</script>

