---
import "../stylesheets/global.css";
import "../stylesheets/navbar.css";

const { title } = Astro.props;

import ClientRouter from "astro/components/ClientRouter.astro";
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="tab_icon.ico" />
		<meta name="viewport" content="initial-scale=1.0, user-scalable=no" />
		<meta name="generator" content= {Astro.generator} />
		<title> {title} </title>

	    <link href="https://fonts.googleapis.com/css2?family=Prompt:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">

        <!-- bs -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous" />

        <ClientRouter />
	</head>

    <body style="background-color: #111;">
        <!-- <div> -->
            <slot />    
        <!-- </div> -->
    </body>

    <script is:inline>
        window.gtranslateSettings = {
            "default_language": "ro",
            "native_language_names": true,
            // "languages": ["ro", "en", 'fr', 'de', 'ja', 'it'], 
            "languages": ['ro', 'en'],
            "wrapper_selector": ".gtranslate_wrapper",
            "switcher_horizontal_position": "right",
            "switcher_vertical_position": "bottom",
            "float_switcher_open_direction": "top",
            "flag_style": "3d"
        }
    </script>

    <script src="https://cdn.gtranslate.net/widgets/latest/flags.js" defer is:inline></script>
</html>

<script>
	// force remove the astro menu during testing
	document.addEventListener("astro:page-load", () => {
		console.log("Connected");

		const astro = document.querySelector("astro-dev-toolbar");
		if (astro) 
			astro.style.display = "none";
	})
</script>

<style is:global>
    #google_translate_element2,
    .skiptranslate:not(.glink) {
        display: none !important;
    }

    body {
        top: 0 !important;
    }

    .gtranslate_wrapper {
        display: flex;
        flex-direction: row;
    }
</style>

<!-- 3. ClientRouter lifecycle hooks -->
<script>
  // Before each swap: steal the entire wrapper out of the old DOM
  // and stash it on window so the new DOM can adopt it.
    document.addEventListener('astro:before-swap', (e) => {
        const wrapper = document.querySelector('.gtranslate_wrapper');
        if (wrapper) {
            window.__gtranslate_wrapper = wrapper;
            wrapper.remove(); // detach from old DOM so it doesn't get destroyed
        }
    });

  // After each swap: re-inject the rescued wrapper into the new DOM.
  // The new page's .gtranslate_wrapper placeholder gets replaced.
  document.addEventListener('astro:after-swap', () => {
        const stashed = window.__gtranslate_wrapper;
        if (!stashed) return;

        const placeholder = document.querySelector('.gtranslate_wrapper');
        if (placeholder) {
            placeholder.replaceWith(stashed);
        } else {
            document.body.appendChild(stashed);
        }

        stashed.style.display = 'flex';
        stashed.style.flexDirection = 'row';
    });

    // After page fully loads: re-apply the active translation to new content.
    document.addEventListener('astro:page-load', () => {
        const gt = window.gtranslateSettings;
        if (!gt || typeof window.doGTranslate !== 'function') return;

        const match = document.cookie.match('(^|;) ?googtrans=([^;]*)(;|$)');
        const currentLang = match?.[2]?.split('/')?.[2];

        if (currentLang && currentLang !== gt.default_language) {
            window.doGTranslate(`${gt.default_language}|${currentLang}`);
        }

        // document.getElementById("google_translate_element2")?.remove();
    });
</script>


<!-- swiper -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"/>
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" is:inline />

<script is:inline>
    function initSwiper() {
        new Swiper(".mySwiper", {
            effect: "coverflow",
            grabCursor: true,
            centeredSlides: true,
            slidesPerView: "auto",
            initialSlide: Math.floor(document.querySelectorAll('.swiper-slide').length / 2),
            coverflowEffect: {
                rotate: 50,
                stretch: 0,
                depth: 100,
                modifier: 0.9,
                slideShadows: true,
            },
            pagination: {
                el: ".swiper-pagination",
            },
        });
    }

    document.addEventListener('astro:page-load', initSwiper);
</script>