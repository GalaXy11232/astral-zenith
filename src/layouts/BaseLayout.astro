---
import { ClientRouter } from "astro:transitions";
import "../stylesheets/global.css";
import "../stylesheets/navbar.css";

const { title } = Astro.props;

---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="tab_icon.ico" />
		<meta name="viewport" content="initial-scale=1.0, user-scalable=no" />
		<meta name="generator" content= {Astro.generator} />
		<title> {title} </title>

	    <link href="https://fonts.googleapis.com/css2?family=Prompt:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">

        <!-- bs -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous" />

		<!-- <ClientRouter /> -->
	</head>

    <body style="background-color: #111;">
        <div>
            <slot />    
        </div>
    </body>

    <div class="gtranslate_wrapper"></div>

    <script>
        window.gtranslateSettings = {
            "default_language": "ro",     /* Your base language */
            "native_language_names": true,
            "languages": ["ro", "en"],    /* ONLY show Romanian and English */
            "wrapper_selector": ".gtranslate_wrapper",
            "switcher_horizontal_position": "right",
            "switcher_vertical_position": "bottom",
            "float_switcher_open_direction": "top",
            "flag_style": "2d"            /* Clean, modern flags */
        }
    </script>

    <script src="https://cdn.gtranslate.net/widgets/latest/float.js" defer></script>
</html>

<script>
	// force remove the astro menu during testing
	document.addEventListener("astro:page-load", () => {
		console.log("Connected");

		const astro = document.querySelector("astro-dev-toolbar");
		if (astro) 
			astro.style.display = "none";
	})
</script>

<script>
    function initGTranslate() {
        // Prevent duplicate engine attachments by removing any existing ones
        const oldScript = document.getElementById('gtranslate-engine');
        if (oldScript) {
            oldScript.remove();
        }

        // Build a brand new script tag to force the engine to run on the new page DOM
        const script = document.createElement('script');
        script.id = 'gtranslate-engine';
        script.src = 'https://cdn.gtranslate.net/widgets/latest/float.js';
        script.defer = true;
        
        document.body.appendChild(script);
    }

    // Fire on the initial hard load AND every single client-side page switch
    // document.addEventListener('astro:page-load', initGTranslate);
</script>