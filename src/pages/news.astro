---
import BaseLayout from "../layouts/BaseLayout.astro"
import NavBar from "../components/NavBar.astro"
import Hexbackground from "../components/hexbackground.astro"

import MediaEvent from '../components/media/MediaEvent.astro';
import MediaLink  from '../components/media/MediaLink.astro';
import MediaImage from '../components/media/MediaImage.astro';
import MediaVideo from '../components/media/MediaVideo.astro';
---


<BaseLayout title = "Știri">
    <NavBar activeLink = {6} />
    <Hexbackground />

    <MediaEvent
        title="Istanbul Premier Event - Premiul Inspire 2"
        date="26 - 28 iunie 2026"
        cover="/assets/coperta articole/Echipa_regionala.webp"
    >
        <span class="me-label">Articole & surse</span>
        <div class="me-grid">
            <MediaLink 
                href="https://www.ziar.com/news=17680422" 
                source="Ziar.com" 
                label="Performanță de elită pentru echipa de robotică Zenith" 
            />
            <MediaLink 
                href="https://www.news.ro/edu-news/performanta-elita-echipa-robotica-zenith-colegiul-national-grigore-moisil-capitala-membrii-echipei-au-obtinut-locul-ii-categoria-inspire-unei-competitii-profil-istanbul-foto-1922402202102026071722502955"  
                source="News.ro"   
                label="Performanţă de elită pentru echipa de robotică Zenith" 
            />

            <MediaLink 
                href="https://financialintelligence.ro/performanta-de-elita-pentru-echipa-de-robotica-zenith-de-la-colegiul-national-grigore-moisil-la-ftc-premier-event-istanbul-2026/"
                source="Financial Intelligence"   
                label="Performanţă de elită pentru echipa de robotică Zenith" 
            />
        </div>

        <hr class="me-divider" />

        <span class="me-label">Galerie foto & video</span>
        <div class="me-media-grid">
            <MediaImage src="/assets/galerie/7_Hackaton_la_Facultatea_de_Inginerie_Mecanică_și_Mecatronică/WhatsApp Image 2026-03-26 at 22.07.49.webp" alt="Echipa pe teren" focus="center top" />
            <MediaImage src="/assets/galerie/7_Hackaton_la_Facultatea_de_Inginerie_Mecanică_și_Mecatronică/WhatsApp Image 2026-03-26 at 22.07.57.webp" alt="Robotul în acțiune" />
            <MediaVideo src="https://www.youtube.com/watch?v=_koqmYqoH6g" poster="/assets/galerie/35_Meet_The_Future,_13_ian._2024/DSC07271.webp" />
        </div>
    </MediaEvent>
</BaseLayout>