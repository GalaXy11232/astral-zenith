---
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import GalleryImageVisualizer from "../components/gallery_image_visualizer.astro";
---

<BaseLayout title="Galerie">
    <NavBar activeLink={5} />

    <GalleryImageVisualizer />
    <div class="gallery" id="gallery-root">
        <div class="gallery-loading">Se încarcă galeria...</div>
    </div>
</BaseLayout>

<style is:global>
    .gallery-folder {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        margin: 1rem;
        flex-wrap: wrap;
    }

    .gallery-folder { margin-bottom: 8rem; }
    .no-mb { margin-bottom: 0 !important; }

    .images {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 2rem;
    }

    .square-image {
        width: 250px; 
        height: 250px;
        object-fit: cover;
        transition: .3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 0 10px black;
        display: block;
        background: #222;
    }

    .square-image:hover {
        transform: scale(1.05);
        border-radius: 20px;
        box-shadow: 0 0 20px var(--primary), 0 0 20px var(--primary);
        cursor: pointer;
    }
    
</style>

<script>

interface FolderData {
    name: string;
    folderRaw: string;
    url: string;
    images: string[];
}

// lazy loader
function createLazyObserver(): IntersectionObserver {
    return new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            const img = entry.target as HTMLImageElement;
            const real = img.dataset.src;
            if (!real) return;

            img.src = real;
            img.removeAttribute('data-src');
            img.removeAttribute('data-lazy');
            observer.unobserve(img);
        });
    }, {
        // start loading when image is 200px away from the viewport
        rootMargin: '200px',
        threshold: 0,
    });
}


function buildImage(src: string, identifier: string, index: number, observer: IntersectionObserver): HTMLImageElement {
    const img = document.createElement('img');
    img.alt = 'Gallery image';
    img.className = 'square-image gallery-placed-image';
    img.decoding = 'async';
    img.draggable = false;
    img.dataset.identifier = identifier;
    img.dataset.index = String(index);

    // lazy: show shimmer until in view
    img.dataset.src = src;
    img.dataset.lazy = 'true';

    img.addEventListener('click', () => openFullView(img));
    observer.observe(img);
    return img;
}

function buildSection(folder: FolderData, observer: IntersectionObserver): HTMLElement {
    const section = document.createElement('section');
    section.className = 'gallery-folder';

    // title
    const titleContainer = document.createElement('div');
    titleContainer.className = 'title-container';
    const span = document.createElement('span');
    span.className = 'title-underline';
    span.textContent = folder.name;
    titleContainer.appendChild(span);
    section.appendChild(titleContainer);

    // images wrapper
    const imagesDiv = document.createElement('div');
    imagesDiv.className = 'images';

    if (folder.images.length === 0) {
        const p = document.createElement('p');
        p.textContent = 'No images found.';
        imagesDiv.appendChild(p);
    } else {
        folder.images.forEach((imageName, index) => {
            const src = `${folder.url}/${encodeURIComponent(imageName)}`;
            imagesDiv.appendChild(buildImage(src, folder.name, index, observer));
        });
    }

    section.appendChild(imagesDiv);
    return section;
}


function openFullView(img: HTMLImageElement) {
    const visualizer = document.getElementById('image-visualizer') as HTMLImageElement | null;
    if (!visualizer) return;
    const container = visualizer.parentElement as HTMLDivElement;

    window.dispatchEvent(new CustomEvent('open-image-visualizer', {
        detail: {
            identifier: img.dataset.identifier,
            index: img.dataset.index,
        }
    }));

    visualizer.src = img.dataset.src ?? img.src; // use real src
    visualizer.setAttribute('data-visible', 'true');
    container.style.zIndex = '100';
    container.style.background = '#111d';
}


async function initGallery() {
    const root = document.getElementById('gallery-root');
    if (!root) return;

    // avoid double-init on astro:page-load
    if (root.dataset.initialized === 'true') return;
    root.dataset.initialized = 'true';

    root.innerHTML = '<div class="gallery-loading">Se încarcă galeria...</div>';

    let folders: FolderData[];
    try {
        const res = await fetch('/api/gallery.json');
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        folders = await res.json();
    } catch (err) {
        console.error('Failed to load folder list:', err);
        root.innerHTML = '<div class="gallery-loading">Eroare la încărcarea galeriei.</div>';
        return;
    }

    root.innerHTML = '';
    const observer = createLazyObserver();

    // render sections one tick at a time so the browser doesn't block
    for (const folder of folders) {
        root.appendChild(buildSection(folder, observer));
        // yield to browser between sections — keeps UI responsive
        await new Promise(r => setTimeout(r, 0));
    }

    console.log(`Rendered ${folders.length} folders.`);
}

// fallback for non-Astro-routed first load
['astro:page-load', 'DOMContentLoaded'].forEach((ev) => {
    console.log("Nigga")
    document.addEventListener(ev, initGallery);
});
</script>