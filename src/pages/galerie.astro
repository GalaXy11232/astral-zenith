---
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import GalleryImage from "../components/gallery_image.astro";

import { readdirSync } from "fs";
import { join } from "path";

const galerieDir = join(process.cwd(), "public", "assets", "galerie");
const galerieFolders = readdirSync(galerieDir, { withFileTypes: true })
  .filter(entry => entry.isDirectory())
  .map(folderEntry => {
    const folderPath = join(galerieDir, folderEntry.name);
    const images = readdirSync(folderPath, { withFileTypes: true })
      .filter(file => file.isFile())
      .map(file => file.name)
      .filter(name => /\.(jpe?g|png|webp|gif|avif|svg)$/i.test(name))
      .sort();

    return {
      name: folderEntry.name,
      images,
      url: `/assets/galerie/${encodeURIComponent(folderEntry.name)}`,
    };
  });

---

<BaseLayout title="Galerie">
  <NavBar activeLink={5} />

  <div class="gallery">
    {
        galerieFolders.map(folder => (
            <section class="gallery-folder">
                <div class="title-container">
                    <span class="title-underline">
                        { folder.name }
                    </span>
                </div>

                <div class="images">
                    {
                        folder.images.length
                            ? folder.images.map(image => (
                                    <GalleryImage src = { `${folder.url}/${encodeURIComponent(image)}` } />
                                ))
                            : <p>No images found.</p>
                    }
                </div>
            </section>
        ))
    }
  </div>
</BaseLayout>

<style>
    .gallery-folder {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        margin: 1rem;
        flex-wrap: wrap;
    }

    .images {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 2rem;
    }
</style>