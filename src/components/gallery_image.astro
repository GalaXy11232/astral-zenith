---
const { src, identifier, index, ...rest } = Astro.props;
---

<img 
    src={src}
    alt="Gallery image" 
    class="square-image gallery-placed-image"
    loading="lazy"
    decoding="async"
    data-identifier={identifier}
    data-index={index}
    draggable="false"
/>

