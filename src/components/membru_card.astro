---
const { name, department, image, tooltip = "" } = Astro.props;

const TOOLTIP_ABBREVIATIONS: Record<string, string> = {
    'UPB, AC': 'Universitatea POLITEHNICA București - Facultatea de Automatică și Calculatoare',
    'UPB, FIMM': 'Universitatea POLITEHNICA București - Facultatea de Inginerie Mecanică și Mecatronică'
};

const tooltipText = tooltip ? TOOLTIP_ABBREVIATIONS[tooltip] ?? "" : "";
---

<article class="member-card">
    <div class="image-wrapper">
        <img 
            src={image} 
            alt={`Portrait of ${name}`} 
            loading="lazy" 

            onerror = "this.src = '/assets/icons/membru no photo zenith.png'"
        />
    </div>
    <div class="info">
        <h3 class="name" translate="no">{name}</h3>
        <p class="department">{department}</p>

        <span class="facultate-tooltip"><i>{tooltip}</i>
        <div class="facultate-tooltiptext"> <i>{tooltipText}</i> </div>
        </span>
    </div>
</article>

<style>
    :root {
        --tooltip-color: #f9c0ff;
        --text-color: #7b28ae
    }

    .facultate-tooltiptext {
        position: absolute; 
        left: 0; right: 0; 
        margin: auto; margin-top: 1em;
        background-color: var(--tooltip-color); 
        color: var(--text-color);
        border-radius: 15px;
        width: fit-content !important; 
        padding: 5px 2em; font-size: 80%;
        opacity: 1; visibility: hidden;
        transition: .25s ease cubic-bezier(0.47, 0, 0.745, 0.715);
    }
    .facultate-tooltiptext::after { /* arrow */
        content: "";
        position: absolute;
        bottom: 100%;
        left: 50%;
        margin-left: -5px;
        border-width: 5px;
        border-style: solid;
        border-color: transparent transparent var(--tooltip-color) transparent;
    }
    .facultate-tooltip { position: relative; }
    .facultate-tooltip > i { border-bottom: 1px dotted black; cursor: help;}
    .facultate-tooltip:hover div { visibility: visible; opacity: 1;}

    
    .member-card {
        background-color: #efedef; 
        border-radius: 24px;
        padding: 24px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        width: 100%;
        max-width: 200px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
        
        
        transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1), 
                    box-shadow 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    }

    
    .member-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 15px 35px rgba(121, 55, 150, 0.15); 
    }

    /* --- Image Container --- */
    .image-wrapper {
        width: 100%;
        
        aspect-ratio: 3 / 4; 
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 20px;
        background-color: #d1d1d1; 
    }

    .image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        
        
        transition: transform 0.5s ease;
    }

    .member-card:hover .image-wrapper img {
        transform: scale(1.04);
    }

    
    .info {
        display: flex;
        flex-direction: column;
        gap: 6px;
        width: 100%;
    }

    .name {
        margin: 0;
        font-family: 'Prompt', sans-serif;
        font-size: 1.2rem;
        font-weight: 600;
        color: #000000;
        letter-spacing: -0.01em;
        
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.15);
    }

    .department {
        margin: 0;
        font-family: 'Prompt', sans-serif;
        font-size: 1rem;
        font-weight: 500;
        color: #793796;
        line-height: 1.4;
        
        white-space: pre-wrap; 
    }
</style>