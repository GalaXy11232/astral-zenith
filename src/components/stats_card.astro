---
const { end, label, icon, duration = 1500, iconAlt } = Astro.props;
---

<div class="stat-card">
    <div class="stat-card__text">
        <span class="stat-card__number" data-end={end} data-duration={duration}>0</span>
        <p class="stat-card__label" style = "text-transform: capitalize">{label}</p>
    </div>

    <div class="stat-card__icon">
        <img src={icon} alt={iconAlt ?? label} loading="lazy" />
    </div>
</div>

<style>
    @import url("https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@600;700&display=swap");

    .stat-card {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.65rem 1.5rem;
        border-radius: 1.25rem;
        background: linear-gradient(155deg, #ffffff 0%, #f5f1fb 55%, #efe4fb 100%);
        border: 1px solid rgba(147, 51, 234, 0.08);
        box-shadow:
            0 2px 6px rgba(88, 28, 135, 0.06),
            0 10px 24px rgba(88, 28, 135, 0.1);
        transition:
        transform 0.35s ease,
        box-shadow 0.35s ease;
        overflow: hidden;
    }

    .stat-card::before {
        content: "";
        position: absolute;
        inset: 0 0 auto 0;
        height: 3px;
        background: linear-gradient(90deg, #9333ea, #d946ef, #9333ea);
        background-size: 200% 100%;
        opacity: 0.8;
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow:
            0 4px 10px rgba(147, 51, 234, 0.14),
            0 16px 32px rgba(147, 51, 234, 0.2);
    }

    .stat-card__text {
        display: flex;
        flex-direction: column;
        min-width: 0;
    }

    .stat-card__number {
        font-family: "Space Grotesk", system-ui, sans-serif;
        font-size: clamp(2.1rem, 4vw, 2.65rem);
        font-weight: 700;
        line-height: 1;
        letter-spacing: -0.02em;
        font-variant-numeric: tabular-nums;
        background: linear-gradient(135deg, #9333ea 0%, #c026d3 55%, #a855f7 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .stat-card__label {
        margin: 0.55rem 0 0;
        font-weight: 700;
        font-size: 0.92rem;
        color: #7e22ce;
        letter-spacing: 0.01em;
    }

    .stat-card__icon {
        position: relative;
        flex: 0 0 auto;
        width: 3.45rem;
        height: 3.45rem;
        border-radius: 999px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: radial-gradient(circle at 30% 28%, #f6d5fe 0%, #ddd3fb 75%);
        box-shadow:
            inset 0 0 0 1px rgba(255, 255, 255, 0.7),
            0 8px 18px rgba(147, 51, 234, 0.25);
        transition: transform 0.35s ease;
    }

    .stat-card:hover .stat-card__icon {
        transform: rotate(-8deg) scale(1.08);
    }

    .stat-card__icon img {
        width: 52%;
        height: 52%;
        object-fit: contain;
        filter: drop-shadow(0 2px 3px rgba(60, 10, 90, 0.2));
    }

    @media (max-width: 420px) {
        .stat-card {
            padding: 1.35rem 1.15rem;
        }

        .stat-card__icon {
            width: 3.1rem;
            height: 3.1rem;
        }
    }
</style>

<script>
    function formatNumber(value: any) {
        try {
            return value.toLocaleString("ro-RO"); // cu formatare (1.234.567)
        } catch {
            return String(value); // fara formatare (1234567)
        }
    }

    function animateCount(el: any) {
        const end = Number(el.dataset.end || "0");
        const duration = Number(el.dataset.duration || "1500");

        if (!end || duration <= 0) {
            el.textContent = formatNumber(end);
            return;
        }

        const steps = Math.max(1, Math.min(end, 60));
        const increment = end / steps;
        const intervalTime = duration / steps;

        let current = 0;
        let tick = 0;

        const timer = setInterval(() => {
            tick += 1;
            current += increment;

        if (tick >= steps) {
            el.textContent = formatNumber(end);
            clearInterval(timer);
            return;
        }

        el.textContent = formatNumber(Math.round(current));
        }, intervalTime);
    }

    function initStatCounters() {
        document
        .querySelectorAll(".stat-card__number[data-end]")
        .forEach((el: any) => {
            if (el.dataset.counted === "true") 
                return;
            
            el.dataset.counted = "true";
            animateCount(el);
        });
    }

    document.addEventListener('astro:page-load', initStatCounters);
</script>