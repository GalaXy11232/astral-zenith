---
const { name, logo, website, tier, scale_factor = 1, light_icon = true } = Astro.props;

const tierColors: Record<string, string> = {
    bronze:   '#5c302d',
    gold:     '#c9a84c',
    silver:   '#9aa0a8',
    platinum: '#4cafd4',
    diamond:  '#5D57FF',
    partener: '#ffffff',
};
const accentColor = tierColors[tier ?? ''] ?? 'var(--primary, #7c3aed)';
---

<div class="sponsor-col">
    <a
        href={website}
        target={website === '#' ? '_self' : '_blank'}
        rel="noopener noreferrer"
        class="sponsor-card"
        aria-label={website !== '#' ? `Vizitează website-ul ${name}` : name}
        style={`--accent: ${accentColor};`}
        data-light={light_icon ? 'true' : 'false'}
    >
        <span class="corner-notch" aria-hidden="true" style={`display: ${website === '#' ? 'none' : 'block'}`}></span>

        {tier && <span class="tier-badge" translate="no">{tier}</span>}

        <span class="card-glow" aria-hidden="true"></span>
        <span class="card-shine" aria-hidden="true"></span>

        <div class="logo-container">
            <img
                src={logo}
                alt={`${name} logo`}
                class="sponsor-logo"
                loading="lazy"
                decoding="async"
                draggable="false"
                style={`transform: scale(${scale_factor});`}
            />
        </div>

        {website !== '#' ? (
            <div class="visit-strip">
                <span class="visit-label" style={`color: ${tier === 'partener' ? '#000' : '#fff'}`}>
                    Vizitează website-ul
                </span>
                <svg class="visit-arrow" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
        ) : (
            <div class="visit-strip-placeholder"></div>
        )}
    </a>
</div>

<style>
    .sponsor-col {
        display:         flex;
        justify-content: center;
        align-items:     center;
        padding:         0.5rem;
    }

    .sponsor-card {
        --card-size:      clamp(140px, 20vw, 200px);
        --card-bg:        #111118;
        --card-border:    rgba(255, 255, 255, 0.08);
        --strip-h:        44px;
        --radius:         14px;
        --notch:          22px;
        --transition:     0.5s cubic-bezier(0.175, 0.885, 0.32, 1);
        --shine-duration: 6s;
        --shine-delay:    0s;

        position:        relative;
        display:         flex;
        flex-direction:  column;
        width:           var(--card-size);
        height:          var(--card-size);
        border-radius:   var(--radius);
        overflow:        hidden;
        text-decoration: none;
        outline:         none;
        cursor:          pointer;
        flex-shrink:     0;
        background:      var(--card-bg);
        border:          1px solid var(--card-border);
        box-shadow:      0 0 0 0 transparent, 0 2px 8px rgba(0, 0, 0, 0.4);
        transition:      box-shadow var(--transition), transform var(--transition);
        user-select:     none;
        -webkit-user-select: none;
    }

    .sponsor-card:hover,
    .sponsor-card:focus-visible {
        transform:  translateY(-3px);
        box-shadow: 0 0 0 1px var(--accent), 0 12px 28px rgba(0, 0, 0, 0.55);
    }

    .corner-notch {
        position:   absolute;
        top:        0;
        right:      0;
        z-index:    4;
        width:      var(--notch);
        height:     var(--notch);
        background: var(--accent);
        clip-path:  polygon(100% 0, 100% 100%, 0 0);
        opacity:    0.9;
        transition: transform var(--transition), opacity var(--transition);
    }
    .sponsor-card:hover .corner-notch,
    .sponsor-card:focus-visible .corner-notch {
        transform: scale(1.3);
        opacity:   1;
    }

    .tier-badge {
        position:       absolute;
        bottom:         calc(var(--strip-h) + 8px);
        left:           50%;
        transform:      translateX(-50%);
        z-index:        3;
        font-family:    ui-monospace, 'Cascadia Code', monospace;
        font-size:      9px;
        font-weight:    600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        white-space:    nowrap;
        color:          var(--accent);
        opacity:        0.7;
        transition:     opacity var(--transition), bottom var(--transition);
    }
    .sponsor-card:hover .tier-badge,
    .sponsor-card:focus-visible .tier-badge {
        opacity: 0;
        bottom:  calc(var(--strip-h) + 2px);
    }



    
    .card-glow {
        position:       absolute;
        inset:          0;
        z-index:        1;
        pointer-events: none;
        border-radius:  var(--radius);
        background:     radial-gradient(
            ellipse 60% 60% at 50% 48%,
            color-mix(in srgb, var(--accent) 38%, transparent),
            transparent 85%
        );
        animation: glow-breathe 3.8s ease-in-out infinite;
        will-change: transform, opacity;
    }

    @keyframes glow-breathe {
        0%   { transform: scale(0.82); opacity: 0.5; }
        50%  { transform: scale(1.18); opacity: 1;   }
        100% { transform: scale(0.82); opacity: 0.5; }
    }




    .card-shine {
        position:         absolute;
        inset:            0;
        z-index:          5;
        pointer-events:   none;
        border-radius:    var(--radius);
        overflow:         hidden;
        will-change:      opacity;
    }

    .card-shine::after {
        content:    '';
        position:   absolute;
        top:        -50%;
        left:       -140%;
        width:      60%;
        height:     200%;
        background: linear-gradient(
            to right,
            transparent                                              0%,
            transparent                                              30%,
            color-mix(in srgb, var(--accent) 40%, transparent)      44%,
            color-mix(in srgb, var(--accent) 60%, white)             50%,
            color-mix(in srgb, var(--accent) 40%, transparent)      56%,
            transparent                                              70%,
            transparent                                              100%
        );
        transform:        rotate(0deg) skewX(-15deg);
        animation:        card-shine-sweep var(--shine-duration, 6s) ease-in-out infinite;
        animation-delay:  var(--shine-delay, 0s);
        will-change:      left;
    }

    @keyframes card-shine-sweep {
        0%   { left: -140%; opacity: 0;   }
        4%   { opacity: 1;               }
        30%  { left:  180%; opacity: 1;   }
        32%  { opacity: 0;               }
        100% { left:  180%; opacity: 0;   }
    }

    .logo-container {
        position:        relative;
        z-index:         2;
        flex:            1;
        display:         flex;
        align-items:     center;
        justify-content: center;
        padding:         clamp(12px, 3vw, 28px) clamp(10px, 2.5vw, 24px) 0;
        transition:      transform var(--transition);
        overflow:        hidden;
    }
    .sponsor-card:hover .logo-container,
    .sponsor-card:focus-visible .logo-container {
        transform: translateY(-4px) scale(1.04);
    }

    .sponsor-logo {
        max-width:   100%;
        max-height:  clamp(50px, 8vw, 80px);
        width:       auto;
        height:      auto;
        object-fit:  contain;
        display:     block;
        transition:  filter var(--transition);
    }

    

    .sponsor-card:not([data-light='true']) .sponsor-logo {
        filter: grayscale(55%) brightness(0.85);
    }
    .sponsor-card:not([data-light='true']):hover .sponsor-logo,
    .sponsor-card:not([data-light='true']):focus-visible .sponsor-logo {
        filter: grayscale(0%) brightness(1.05);
    }
    .sponsor-card[data-light='true'] .sponsor-logo {
        filter: brightness(0.92);
    }
    .sponsor-card[data-light='true']:hover .sponsor-logo,
    .sponsor-card[data-light='true']:focus-visible .sponsor-logo {
        filter: brightness(1.08);
    }

    .visit-strip {
        position:        relative;
        z-index:         3;
        display:         flex;
        align-items:     center;
        justify-content: center;
        gap:             6px;
        height:          var(--strip-h);
        flex-shrink:     0;
        background:      var(--accent);
        transform:       translateY(100%);
        transition:      transform var(--transition);
    }
    .sponsor-card:hover .visit-strip,
    .sponsor-card:focus-visible .visit-strip {
        transform: translateY(0%);
    }

    .visit-strip-placeholder {
        height:     var(--strip-h);
        flex-shrink: 0;
    }

    .visit-label {
        font-family:    ui-monospace, 'Cascadia Code', monospace;
        font-size:      10px;
        font-weight:    600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        white-space:    nowrap;
    }

    .visit-arrow {
        width:      13px;
        height:     13px;
        color:      #fff;
        flex-shrink: 0;
        transform:  translateX(0);
        transition: transform var(--transition);
    }
    .sponsor-card:hover .visit-arrow,
    .sponsor-card:focus-visible .visit-arrow {
        transform: translateX(3px);
    }

    .sponsor-card:focus-visible {
        outline:        2px solid var(--accent);
        outline-offset: 3px;
    }

    /* @media (prefers-reduced-motion: reduce) {
        .sponsor-card,
        .sponsor-card * {
            transition: none !important;
            animation:  none !important;
        }
        .visit-strip {
            transform: translateY(0%) !important;
            opacity:   0;
        }
        .sponsor-card:hover .visit-strip,
        .sponsor-card:focus-visible .visit-strip {
            opacity: 1;
        }
    } */
</style>