---
interface Props {
    href: string;
    source: string;
    label: string;
}
const { href, source, label } = Astro.props;
---
<a href={href} target="_blank" rel="noopener noreferrer" class="me-link">
    <span class="me-link-icon">
        <svg viewBox="0 0 24 24">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
        </svg>
    </span>
    <span class="me-link-text">
        <span class="me-link-source">{source}</span>
        <span class="me-link-label">{label}</span>
    </span>
</a>
