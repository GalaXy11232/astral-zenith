---
interface Props {
    src: string;
    alt?: string;
    focus?: string;
}
const { src, alt = '', focus = 'center' } = Astro.props;
---
<div class="me-img-wrap">
    <img src={src} alt={alt} loading="lazy" decoding="async" draggable="false" style={`object-position:${focus}`} />
    <div class="me-media-badge">
        <div class="me-media-badge-inner">
            <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </div>
    </div>
</div>
