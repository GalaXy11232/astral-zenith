---
export interface Props {
    url: string;
    title?: string;
    aspectRatio?: string;
}

const { url, title = '', aspectRatio = "16 / 9" } = Astro.props;

function getEmbedUrl(source: string) {
    const watchMatch = source.match(/[?&]v=([^&]+)/);
    if (source.includes("youtube.com/watch") && watchMatch) {
        return `https://www.youtube.com/embed/${watchMatch[1]}`;
    }
    const shortMatch = source.match(/youtu\.be\/([^?&]+)/);
    if (shortMatch) {
        return `https://www.youtube.com/embed/${shortMatch[1]}`;
    }
    return source;
}

const embedUrl = getEmbedUrl(url);
---

<section class="video-section">
    {title && (
        <div class="video-section__heading">
        <span class="video-section__bar" aria-hidden="true"></span>
        <p class="video-section__label">{title}</p>
        </div>
    )}
    <div class="video-section__frame" style={`aspect-ratio:${aspectRatio};`}>
        <iframe
            src={embedUrl}
            title={title ?? "Video"}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
        ></iframe>
    </div>
</section>

<style>
    .video-section {
        width: min(92vw, max(1050px, 80dvh));
        margin-inline: auto;
        padding: 3.5rem 1.5rem;
        /* font-family: system-ui, -apple-system, "Segoe UI", sans-serif; */
    }

    .video-section__heading {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        margin-bottom: 1.4rem;
    }

    .video-section__bar {
        flex: 0 0 auto;
        width: 4px;
        height: 1.4rem;
        border-radius: 999px;
        background: linear-gradient(180deg, #9333ea, #d946ef);
    }

    .video-section__label {
        margin: 0;
        font-weight: 700;
        font-size: 0.82rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #d8b4fe;
    }

    .video-section__frame {
        position: relative;
        width: 100%;
        border-radius: 1.35rem;
        overflow: hidden;
        background: #0a0512;
        border: 1px solid rgba(168, 85, 247, 0.25);
        box-shadow:
            0 0 0 1px rgba(147, 51, 234, 0.08),
            0 24px 60px rgba(88, 28, 135, 0.45),
            0 0 46px rgba(168, 85, 247, 0.18);
    }

    .video-section__frame iframe {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        display: block;
        border: 0;
    }
</style>
