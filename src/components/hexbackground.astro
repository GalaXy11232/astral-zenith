---
// HexBackground.astro
// Places the viewer inside a cylinder made of hexagon rings.
// Odd rings rotate clockwise, even rings counter-clockwise.
// Rings move infinitely up or down, wrapping seamlessly.
---
<canvas id="hex-bg-canvas"></canvas>

<style>
    #hex-bg-canvas {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: -1;
        display: block;
        pointer-events: none;
    }
</style>

<script>
const CONFIG = {
    backgroundColor: '#0d0d12',
    fog: { color: '#0d0d12', near: 8, far: 40 },

    camera: {
        fov:      75,
        near:     0.1,
        far:      100,
        position: [0, 0, 0] as [number, number, number],
    },

    cylinder: {
        radius:      9,
        hexPerRing:  12,
        rings:       14,
        ringSpacing: 2.2,
        yOffset:    -4,
    },

    shape: {
        radius:    0.85,
        thickness: 0.12,
    },

    colors: {
        palette: [
            0x7c3aed, 0x6d28d9, 0x5b21b6,
            0x4c1d95, 0x8b5cf6, 0x3b0764,
        ],
        opacity:     0.4,
        flatShading: true,
    },

    lights: {
        ambient:     { color: 0xffffff, intensity: 0.35 },
        directional: [
            { color: 0xa855f7, intensity: 1.4, position: [0,  8,  2] as [number,number,number] },
            { color: 0x4f46e5, intensity: 0.6, position: [0, -6, -2] as [number,number,number] },
        ],
    },

    motion: {
        ringSpeed:         0.001,
        parallax:          0.18,
        parallaxEase:      0.03,
        verticalSpeed:     0.002, // How fast the rings move up/down
        verticalDirection: -1,    // 1 for UP, -1 for DOWN
    },
};

const pick = <T>(arr: T[]): T => arr[Math.floor(Math.random() * arr.length)];

async function initBackground() {
    const canvas = document.getElementById('hex-bg-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    if ((canvas as any)._initialized) return;
    (canvas as any)._initialized = true;

    let THREE: any;
    try {
        THREE = await import('three');
    } catch {
        console.warn('[HexBG] three not found — run: npm i three');
        return;
    }

    // Renderer
    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: false });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(window.innerWidth, window.innerHeight);

    // Scene
    const scene = new THREE.Scene();
    scene.background = new THREE.Color(CONFIG.backgroundColor);
    scene.fog = new THREE.Fog(CONFIG.fog.color, CONFIG.fog.near, CONFIG.fog.far);

    // Camera
    const camera = new THREE.PerspectiveCamera(
        CONFIG.camera.fov,
        window.innerWidth / window.innerHeight,
        CONFIG.camera.near,
        CONFIG.camera.far,
    );
    camera.position.set(...CONFIG.camera.position);

    // Lights
    scene.add(new THREE.AmbientLight(CONFIG.lights.ambient.color, CONFIG.lights.ambient.intensity));
    for (const dl of CONFIG.lights.directional) {
        const l = new THREE.DirectionalLight(dl.color, dl.intensity);
        l.position.set(...dl.position);
        scene.add(l);
    }

    // Shared hexagon geometry
    const hexGeo = new THREE.CylinderGeometry(
        CONFIG.shape.radius,
        CONFIG.shape.radius,
        CONFIG.shape.thickness,
        6, 1, false,
    );
    hexGeo.rotateX(Math.PI / 2);

    // Build rings
    const { radius, hexPerRing, rings, ringSpacing, yOffset } = CONFIG.cylinder;
    const ringGroups: any[] = [];

    for (let r = 0; r < rings; r++) {
        const group = new THREE.Group();
        group.position.y = yOffset + (r - (rings - 1) / 2) * ringSpacing;

        for (let h = 0; h < hexPerRing; h++) {
            const angle = (h / hexPerRing) * Math.PI * 2;

            const mat = new THREE.MeshStandardMaterial({
                color:       pick(CONFIG.colors.palette),
                opacity:     CONFIG.colors.opacity,
                transparent: CONFIG.colors.opacity < 1,
                flatShading: CONFIG.colors.flatShading,
            });

            const mesh = new THREE.Mesh(hexGeo, mat);

            // Place on cylinder surface
            mesh.position.x = Math.sin(angle) * radius;
            mesh.position.z = Math.cos(angle) * radius;

            // Face the hexagon inward toward the viewer at the origin
            mesh.rotation.y = angle + Math.PI;

            group.add(mesh);
        }

        scene.add(group);
        ringGroups.push(group);
    }

    // Mathematical boundaries for the infinite loop
    const totalHeight = rings * ringSpacing;
    const halfHeight = totalHeight / 2;

    // Mouse parallax state
    let targetRotX = 0, targetRotY = 0;
    let currentRotX = 0, currentRotY = 0;

    const onMouse = (e: MouseEvent) => {
        targetRotY =  (e.clientX / window.innerWidth  - 0.5) * 2 * CONFIG.motion.parallax;
        targetRotX = -(e.clientY / window.innerHeight - 0.5) * 2 * CONFIG.motion.parallax;
    };
    window.addEventListener('mousemove', onMouse);

    const onResize = () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
    };
    window.addEventListener('resize', onResize);

    let rafId: number;

    const animate = () => {
        rafId = requestAnimationFrame(animate);

        // Apply animations to each ring
        for (let r = 0; r < ringGroups.length; r++) {
            const group = ringGroups[r];
            
            // 1. Alternate ring rotation direction
            group.rotation.y += CONFIG.motion.ringSpeed * (r % 2 === 0 ? 1 : -1);

            // 2. Vertical continuous movement
            group.position.y += CONFIG.motion.verticalSpeed * CONFIG.motion.verticalDirection;

            // 3. Infinite Wrapping Logic
            // Calculate distance from the original center offset
            const dy = group.position.y - yOffset;
            
            // If the ring moves past the top boundary, snap it to the bottom
            if (dy > halfHeight) {
                group.position.y -= totalHeight;
            } 
            // If the ring moves past the bottom boundary, snap it to the top
            else if (dy < -halfHeight) {
                group.position.y += totalHeight;
            }
        }

        // Smooth camera parallax
        const ease = CONFIG.motion.parallaxEase;
        currentRotX += (targetRotX - currentRotX) * ease;
        currentRotY += (targetRotY - currentRotY) * ease;

        camera.quaternion.setFromEuler(
            new THREE.Euler(currentRotX, currentRotY, 0, 'YXZ')
        );

        renderer.render(scene, camera);
    };

    animate();

    const cleanup = () => {
        cancelAnimationFrame(rafId);
        window.removeEventListener('mousemove', onMouse);
        window.removeEventListener('resize', onResize);
        renderer.dispose();
        hexGeo.dispose();
        ringGroups.forEach(g => g.children.forEach((m: any) => m.material.dispose()));
        document.removeEventListener('astro:before-swap', cleanup);
        (canvas as any)._initialized = false;
    };
    document.addEventListener('astro:before-swap', cleanup);
}

['astro:page-load', 'DOMContentLoaded'].forEach((ev) => {
    document.addEventListener(ev, initBackground);
});

</script>