---
const { date, title,  image, imageAlt} = Astro.props;
---

<article class="result-card">
    <div style = "margin-bottom: 6.7px;">
        <span class="result-card__date">{date}</span>
    </div>

    <div class="result-card__panel">
        <div class="result-card__media">
        <img src={ image} alt={imageAlt ?? title} loading="lazy" />
        </div>

        <div class="result-card__content">
        <h3 class="result-card__title">{title}</h3>
        <div class="result-card__description">
            <slot />
        </div>
        </div>
    </div>
</article>

<style>
    .result-card {
        position: relative;
        padding-top: 1.85rem;
    }


    .result-card__date {
        position: absolute;
        top: 0; 
        right: 1.5rem;
        display: inline-block;
        padding: 0.4rem 1.1rem;
        background: linear-gradient(135deg, #a21caf, #9333ea);
        color: #fff;
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.01em;
        border-radius: 999px;
        box-shadow: 0 4px 10px rgba(126, 34, 206, 0.35);
        white-space: nowrap;
    }


    .result-card__panel {
        position: relative;
        display: flex;
        gap: 1.5rem;
        align-items: center;
        background: #e6def6;
        border-radius: 1rem;
        padding: 1.5rem;
        box-shadow: 0 20px 35px rgba(88, 28, 135);
    }


    .result-card__panel::before {
        content: "";
        position: absolute;
        top: 2.1rem;
        right: -0.6rem;
        width: 1.2rem;
        height: 1.2rem;
        background: inherit;
        border-radius: 0.25rem;
        transform: rotate(45deg);
    }

    .result-card__media {
        flex: 0 0 auto;
        width: 6.5rem;
        height: 6.5rem;
        border-radius: 0.75rem;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        /* background: #ffffff; */
    }

    .result-card__media img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .result-card__content {
        flex: 1 1 auto;
        min-width: 0;
    }

    .result-card__title {
        margin: 0 0 0.5rem;
        font-size: 1.15rem;
        font-weight: 700;
        color: #8b2fd6;
    }

    .result-card__description {
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.6;
        color: #2c2440;
        text-align: justify;
    }

    .result-card__description :global(p) {
        margin: 0 0 0.6em;
    }

    .result-card__description :global(p:last-child) {
        margin-bottom: 0;
    }


    @media (max-width: 640px) {
        .result-card {
            padding-top: 0;
        }

        .result-card__date {
            position: static;
            display: inline-block;
            margin-bottom: 0.75rem;
        }

        .result-card__panel {
            flex-direction: column;
            text-align: center;
        }

        .result-card__panel::before {
            display: none;
        }
    }
</style>