---
interface Props {
    motto:      string;
    subtitle:     string;
    robotImage:   string;
    modelSrc:    string;
    robotAlt?:    string;
    modelPoster?: string;
}

const {
    motto,
    subtitle,
    robotImage,
    modelSrc,
    robotAlt    = 'Robot Image',
    modelPoster = '',
} = Astro.props;
---

<script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>

<section class="hero">

    <div class="hero-inner">

        <div class="hero-text">
            <span class="hero-eyebrow">FTC Team #19084</span>
            <h1 class="hero-headline">
                {motto.split(' ').map((word, i) => (
                    <span class="hero-word" style={`--i: ${i}`}>{word}</span>
                ))}
            </h1>
            <p class="hero-sub">{subtitle}</p>
            <div class="hero-rule" aria-hidden="true"></div>
        </div>

        <div class="hero-visual">

            <div class="robot-frame" id="robot-frame">

                <div class="robot-view visible" id="robot-photo-view">
                    <img
                        src={robotImage}
                        alt={robotAlt}
                        class="robot-img"
                        draggable="false"
                        decoding="async"
                    />
                </div>

                <div class="robot-view" id="robot-model-view">
                    <model-viewer
                        id="robot-model-viewer"
                        class="robot-model-viewer"
                        data-src={modelSrc}
                        poster={modelPoster || undefined}
                        alt={robotAlt}
                        camera-controls
                        shadow-intensity="1"
                        exposure="0.9"
                        reveal="manual"
                    ></model-viewer>

                    <div class="model-spinner" id="model-spinner">
                        <div class="spinner-ring"></div>
                        <span class="spinner-label">Se încarcă modelul</span>
                    </div>
                </div>
            </div>

            <button class="model-toggle" id="model-toggle" aria-pressed="false">
                <span class="toggle-icon" id="toggle-icon">
                    <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
                        <path d="M10 2L18 6.5V13.5L10 18L2 13.5V6.5L10 2Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
                        <path d="M10 2V18M2 6.5L10 11L18 6.5" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
                    </svg>
                </span>
                <span id="toggle-label">Vezi modelul 3D</span>
            </button>

        </div>

    </div>

    <!-- <div class="hero-scroll" aria-hidden="true">
        <span class="scroll-line"></span>
        <span class="scroll-dot"></span>
    </div> -->

</section>

<style>
    .hero {
        --ac:      #7c3aed;
        --ac-mid:  #a78bfa;
        --text:    #f0eeff;
        --muted:   #8b87a8;
        --tr:      0.38s cubic-bezier(0.22, 1, 0.36, 1);

        position:        relative;
        height:      100dvh;
        display:         flex;
        flex-direction:  column;
        justify-content: center;
        padding:         clamp(80px, 12vh, 120px) clamp(20px, 6vw, 80px) 60px;
        box-sizing:      border-box;
        overflow:        hidden;
    }

    .hero-inner {
        display:         flex;
        align-items:     center;
        justify-content: center;
        gap:             clamp(32px, 6vw, 80px);
        width:           100%;
        max-width:       1100px;
        margin:          0 auto;
    }

    .hero-text {
        flex:      1;
        min-width: 0;
        z-index:   2;
        text-align: center;
    }

    .hero-eyebrow {
        display:        block;
        /* font-family:    ui-monospace, 'Cascadia Code', monospace; */
        font-size:      clamp(0.65rem, 1.2vw, 0.78rem);
        font-weight:    600;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color:          var(--ac-mid);
        margin-bottom:  clamp(14px, 2.5vh, 22px);
        opacity:        0;
        transform:      translateY(10px);
        animation:      fade-up 0.7s 0.1s ease forwards;
    }

    .hero-headline {
        /* font-family:    system-ui, -apple-system, 'Segoe UI', sans-serif; */
        font-size:      clamp(2.4rem, 6.5vw, 5rem);
        font-weight:    800;
        line-height:    1.05;
        letter-spacing: -0.03em;
        color:          var(--text);
        margin:         0 0 clamp(16px, 3vh, 26px);
        display:        flex;
        justify-content: center;
        flex-wrap:      wrap;
        gap:            0.3em;
    }

    .hero-word {
        display:   inline-block;
        opacity:   0;
        transform: translateY(24px);
        animation: fade-up 0.6s calc(0.25s + var(--i) * 0.1s) cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .hero-sub {
        /* font-family:    system-ui, -apple-system, 'Segoe UI', sans-serif; */
        font-size:      clamp(0.9rem, 1.8vw, 1.1rem);
        font-weight:    400;
        line-height:    1.65;
        color:          var(--muted);
        text-align:     center;
        margin:         0 0 clamp(20px, 4vh, 32px);
        /* max-width:      42ch; */
        width: 100%;
        opacity:        0;
        transform:      translateY(12px);
        animation:      fade-up 0.7s 0.55s ease forwards;
    }

    .hero-rule {
        width:            48px;
        height:           2px;
        background:       var(--ac);
        border-radius:    2px;
        opacity:          0;
        transform:        scaleX(0);
        transform-origin: left;
        animation:        rule-in 0.6s 0.7s ease forwards;
        margin: auto;
    }

    .hero-visual {
        flex:            0 0 auto;
        display:         flex;
        flex-direction:  column;
        align-items:     center;
        gap:             20px;
        z-index:         2;
        opacity:         0;
        transform:       translateY(20px);
        animation:       fade-up 0.8s 0.35s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .robot-frame {
        --robot-zoom:     1;
        --robot-position: 75% 50%;

        position:      relative;
        width:         clamp(240px, 36vw, 420px);
        aspect-ratio:  3 / 4;
        clip-path:     polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
        background:    rgba(13, 13, 18, 0.6);
        opacity:       0;
        transform:     scale(0.86);
        animation:
            hex-pulse    4s ease-in-out infinite,
            frame-reveal 0.8s 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .robot-frame:hover {
        animation-play-state: paused, running;
        filter: drop-shadow(0 0 40px rgba(124, 58, 237, 0.65)) drop-shadow(0 16px 48px rgba(0, 0, 0, 0.4));
    }

    @keyframes hex-pulse {
        0%, 100% { filter: drop-shadow(0 0 20px rgba(124, 58, 237, 0.35)) drop-shadow(0 12px 36px rgba(0, 0, 0, 0.35)); }
        50%       { filter: drop-shadow(0 0 34px rgba(124, 58, 237, 0.6))  drop-shadow(0 12px 36px rgba(0, 0, 0, 0.35)); }
    }

    @keyframes frame-reveal {
        to { opacity: 1; transform: scale(1); }
    }

    .robot-view {
        position:        absolute;
        inset:           0;
        display:         flex;
        align-items:     center;
        justify-content: center;
        opacity:         0;
        transition:      opacity 0.45s ease;
        overflow:        hidden;
    }

    .robot-view.visible {
        opacity: 1;
    }

    .robot-img {
        width:           100%;
        height:          100%;
        object-fit:      contain;
        object-position: var(--robot-position);
        transform:       scale(var(--robot-zoom));
        transform-origin: var(--robot-position);
        display:         block;
    }

    .robot-model-viewer {
        width:            100%;
        height:           100%;
        display:          block;
        background:       transparent;
        --poster-color:   transparent;
    }

    .model-spinner {
        display:         flex;
        flex-direction:  column;
        align-items:     center;
        gap:             14px;
        position:        absolute;
        inset:           0;
        justify-content: center;
        background:      rgba(13, 13, 18, 0.6);
    }

    .spinner-ring {
        width:        36px;
        height:       36px;
        border:       2.5px solid rgba(124, 58, 237, 0.2);
        border-top:   2.5px solid var(--ac);
        border-radius: 50%;
        animation:    spin 0.85s linear infinite;
    }

    @keyframes spin {
        to { transform: rotate(360deg); }
    }

    .spinner-label {
        /* font-family:    ui-monospace, 'Cascadia Code', monospace; */
        font-size:      0.65rem;
        font-weight:    600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color:          var(--ac-mid);
    }

    .model-toggle {
        display:         flex;
        align-items:     center;
        gap:             9px;
        padding:         10px 22px;
        background:      rgba(124, 58, 237, 0.12);
        border:          1px solid rgba(124, 58, 237, 0.3);
        border-radius:   100px;
        color:           var(--ac-mid);
        /* font-family:     ui-monospace, 'Cascadia Code', monospace; */
        font-size:       0.75rem;
        font-weight:     600;
        letter-spacing:  0.1em;
        text-transform:  uppercase;
        cursor:          pointer;
        transition:      background var(--tr), border-color var(--tr), color var(--tr), transform var(--tr);
        white-space:     nowrap;
        backdrop-filter: blur(8px);
        opacity:         0;
        animation:       fade-up 0.6s 1.15s ease forwards;
    }

    .model-toggle:hover {
        background:   rgba(124, 58, 237, 0.22);
        border-color: rgba(124, 58, 237, 0.55);
        color:        #fff;
        transform:    translateY(-1px);
    }

    .model-toggle:visible {
        transform: translateY(0);
    }

    .model-toggle[aria-pressed='true'] {
        background:   rgba(124, 58, 237, 0.25);
        border-color: var(--ac);
        color:        #fff;
    }

    .toggle-icon svg {
        width:  16px;
        height: 16px;
        display: block;
        transition: transform var(--tr);
    }

    .model-toggle[aria-pressed='true'] .toggle-icon svg {
        transform: rotate(90deg);
    }

    .hero-scroll {
        position:        absolute;
        bottom:          28px;
        left:            50%;
        transform:       translateX(-50%);
        display:         flex;
        flex-direction:  column;
        align-items:     center;
        gap:             6px;
        opacity:         0;
        animation:       fade-up 0.6s 1.1s ease forwards;
    }

    .scroll-line {
        width:            1px;
        height:           32px;
        background:       linear-gradient(to bottom, transparent, var(--ac-mid));
        animation:        scroll-pulse 2s ease-in-out infinite;
    }

    .scroll-dot {
        width:            5px;
        height:           5px;
        border-radius:    50%;
        background:       var(--ac-mid);
        animation:        scroll-pulse 2s 0.4s ease-in-out infinite;
    }

    @keyframes scroll-pulse {
        0%, 100% { opacity: 0.3; }
        50%       { opacity: 1;   }
    }

    @keyframes fade-up {
        to { opacity: 1; transform: translateY(0) scaleX(1); }
    }

    @keyframes rule-in {
        to { opacity: 1; transform: scaleX(1); }
    }

    @media (max-width: 700px) {
        .hero-inner {
            flex-direction:  column-reverse;
            text-align:      center;
        }

        .hero-sub {
            max-width: none;
        }

        .hero-rule {
            transform-origin: center;
            margin: 0 auto;
        }

        .robot-frame {
            width: clamp(200px, 72vw, 300px);
        }
    }

    /* @media (prefers-reduced-motion: reduce) {
        .hero-eyebrow,
        .hero-word,
        .hero-sub,
        .hero-rule,
        .hero-visual,
        .hero-scroll,
        .model-toggle {
            opacity:   1;
            transform: none;
            animation: none;
        }
        .hero-rule { transform: scaleX(1); }
        .robot-frame {
            opacity: 1;
            transform: scale(1);
            animation: hex-pulse 4s ease-in-out infinite;
        }
        .spinner-ring { animation: spin 1.2s linear infinite; }
        .scroll-line,
        .scroll-dot { animation: none; opacity: 1; }
    } */
</style>

<script>
    function initHero() {
        const toggle      = document.getElementById('model-toggle') as HTMLButtonElement;
        const photoView   = document.getElementById('robot-photo-view') as HTMLDivElement;
        const modelView   = document.getElementById('robot-model-view') as HTMLDivElement;
        const spinner     = document.getElementById('model-spinner') as HTMLDivElement;
        const toggleLabel = document.getElementById('toggle-label') as HTMLSpanElement;
        const modelViewer  = document.getElementById('robot-model-viewer') as any;
 
        if (!toggle || !photoView || !modelView || !spinner || !toggleLabel || !modelViewer)
            return;
 
        if ((toggle as any)._heroInit) return;
        (toggle as any)._heroInit = true;
 
        let modelLoaded  = false;
        let modelShowing = false;
 
        function showModel() {
            photoView.classList.remove('visible');
            modelView.classList.add('visible');
            toggle.setAttribute('aria-pressed', 'true');
            toggleLabel.textContent = 'Înapoi la imagine';
            modelShowing = true;
 
            modelViewer.setAttribute('camera-controls', '');
            modelViewer.setAttribute('auto-rotate', '');
 
            if (!modelLoaded) {
                spinner.style.display = 'flex';
 
                modelViewer.addEventListener('load', () => {
                    spinner.style.display = 'none';
                    modelLoaded = true;
                }, { once: true });
 
                modelViewer.addEventListener('error', (event: any) => {
                    console.error('model-viewer failed to load the model', event.detail ?? event);
                    spinner.querySelector('.spinner-label')!.textContent = 'Modelul nu a putut fi încărcat';
                    spinner.querySelector('.spinner-ring')!.setAttribute('style', 'animation-play-state:paused;border-top-color:#e05252;');
                }, { once: true });
 
                modelViewer.setAttribute('src', modelViewer.dataset.src ?? '');
                modelViewer.dismissPoster?.();
            } else {
                spinner.style.display = 'none';
            }
        }
 
        function showPhoto() {
            modelView.classList.remove('visible');
            photoView.classList.add('visible');
            toggle.setAttribute('aria-pressed', 'false');
            toggleLabel.textContent = 'Vezi modelul 3D';
            modelShowing = false;
 
            modelViewer.removeAttribute('camera-controls');
            modelViewer.removeAttribute('auto-rotate');
        }
 
        toggle.addEventListener('click', () => {
            modelShowing ? showPhoto() : showModel();
        });
    }
 
    document.addEventListener('astro:page-load', initHero);
</script>
