---
export interface Props {
  name: "email" | "instagram" | "tiktok" | "linkedin" | "website" | "mappin" | string;
  size?: number;
}

const { name, size = 22 } = Astro.props;
---

{name === "email" && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <rect x="3" y="5" width="18" height="14" rx="2.5"></rect>
    <path d="M3.5 6.5 12 13 20.5 6.5"></path>
  </svg>
)}

{name === "instagram" && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <rect x="3" y="3" width="18" height="18" rx="5.5"></rect>
    <circle cx="12" cy="12" r="4.2"></circle>
    <circle cx="17.4" cy="6.6" r="1"></circle>
  </svg>
)}

{name === "tiktok" && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <path d="M14 4v9.5a3.5 3.5 0 1 1-3-3.46"></path>
    <path d="M14 4c.4 2.2 2.1 3.9 4.3 4.2"></path>
  </svg>
)}

{name === "linkedin" && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="7" cy="8" r="2.1"></circle>
    <path d="M7 12v7"></path>
    <path d="M13 19v-4.2c0-1.7 1-2.8 2.6-2.8 1.6 0 2.4 1 2.4 2.8V19"></path>
    <path d="M13 12.3V19"></path>
  </svg>
)}

{name === "website" && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="9"></circle>
    <path d="M3 12h18"></path>
    <path d="M12 3c2.5 2.6 4 6 4 9s-1.5 6.4-4 9c-2.5-2.6-4-6-4-9s1.5-6.4 4-9Z"></path>
  </svg>
)}

{name === "mappin" && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 21s-7-6.3-7-11.5a7 7 0 1 1 14 0C19 14.7 12 21 12 21Z"></path>
    <circle cx="12" cy="9.5" r="2.4"></circle>
  </svg>
)}


{name === "youtube" && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <rect x="2.5" y="6" width="19" height="12" rx="4"></rect>
    <path d="M10.3 9.6v4.8l4.4-2.4-4.4-2.4Z"></path>
  </svg>
)}

{name === "facebook" && (
  <svg width={size} height={size} viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
    <mask id="fb-f-cutout">
      <rect x="3" y="3" width="18" height="18" rx="5.5" fill="white"></rect>
      <path
        d="M14 21v-7.2h2.3l.4-2.8H14V9.1c0-.8.2-1.4 1.5-1.4h1.3V5.2c-.2 0-1-.1-2-.1-2 0-3.4 1.2-3.4 3.5V11H9v2.8h2.4V21"
        fill="none"
        stroke="black"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
      ></path>
    </mask>
    <rect x="3" y="3" width="18" height="18" rx="5.5" fill="currentColor" mask="url(#fb-f-cutout)"></rect>
  </svg>
)}

{name === "linktree" && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 21v-6"></path>
    <path d="M12 15 7 10"></path>
    <path d="M12 15l5-5"></path>
    <path d="M12 11V5"></path>
    <circle cx="12" cy="3.4" r="1.4"></circle>
    <circle cx="6" cy="8.6" r="1.4"></circle>
    <circle cx="18" cy="8.6" r="1.4"></circle>
  </svg>
)}