---
import Icon from "./Icon.astro";

export interface Props {
  label: string;
  value: string;
  href: string;
  icon: "email" | "instagram" | "tiktok" | "linkedin" | "website" | string;
  external?: boolean;
}

const { label, value, href, icon, external = true } = Astro.props;
---

<a
  class="contact-card"
  href={href}
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer" : undefined}
>
  <span class="contact-card__icon">
    <Icon name={icon} size={24} />
  </span>
  <span class="contact-card__text">
    <span class="contact-card__label">{label}</span>
    <span class="contact-card__value">{value}</span>
  </span>
</a>

<style>
    .contact-card {
        display: flex;
        align-items: center;
        gap: 1rem;
        width: 100%;
        max-width: 230px;
        flex: 0 1 230px;
        padding: 1.35rem 1.4rem;
        border-radius: 1.1rem;
        text-decoration: none;
        background: linear-gradient(155deg, #ffffff 0%, #f5f1fb 55%, #efe4fb 100%);
        border: 1px solid rgba(147, 51, 234, 0.1);
        box-shadow:
        0 2px 6px rgba(88, 28, 135, 0.06),
        0 10px 24px rgba(88, 28, 135, 0.1);
        transition:
        transform 0.3s ease,
        box-shadow 0.3s ease;
    }

    .contact-card:hover {
        transform: translateY(-4px);
        box-shadow:
        0 4px 10px rgba(147, 51, 234, 0.14),
        0 16px 32px rgba(147, 51, 234, 0.2);
    }

    .contact-card__icon {
        flex: 0 0 auto;
        width: 3.1rem;
        height: 3.1rem;
        border-radius: 999px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #7e22ce;
        background: radial-gradient(circle at 30% 28%, #f6d5fe 0%, #ddd3fb 75%);
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.7);
        transition: transform 0.35s ease;
    }

    .contact-card:hover .contact-card__icon {
        transform: rotate(-6deg) scale(1.06);
    }

    .contact-card__text {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        min-width: 0;
    }

    .contact-card__label {
        font-family: "Space Grotesk", system-ui, sans-serif;
        font-weight: 700;
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #9333ea;
    }

    .contact-card__value {
        font-size: 1rem;
        font-weight: 600;
        color: #3b0764;
        overflow-wrap: anywhere;
    }
</style>
